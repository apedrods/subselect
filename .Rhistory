s_2021 <- sd(INTClogRet["2021",])
library(quantmod)    # Main library for accessing financial data from the Internet
library(moments)     # Required for computing skewness and kurtosis coefficients
library(ggplot2)     # For better graphics
library(ggfortify)   # Required for making ggplot2 to work with xts objects
getSymbols("INTC",from=as.Date("2020-01-01"))
chartSeries(INTC,subset="2010::2024",theme="white",TA=NULL)
INTClogRet <- diff(log(INTC[,"INTC.Adjusted"]))[-1]
names(INTClogRet) <- "DailRet"
n20 <- length(INTClogRet["2020"])
n21 <- length(INTClogRet["2021"])
n22 <- length(INTClogRet["2022"])
n23 <- length(INTClogRet["2023"])
n24 <- length(INTClogRet["2024"])
s_2021 <- sd(INTClogRet["2021",])K_2021 <- kurtosis(INTClogRet["2021",])
s_2021 <- sd(INTClogRet["2021",])
n_2021
n21
K_2021 <- kurtosis(INTClogRet["2021",])
K_2021
n_2021 <- nrow(INTClogRet["2021",])
S_S2021 <- (s_2021/2) * sqrt( ( K_2021 * (n_2021/(n_2021-1))^2 - (n_2021-3)/(n_2021-1) ) / n_2021 )
S_S2021
SigLB_2021 <- s_2021 - qnorm(0.975) * S_S2021
SigUB_2021 <- s_2021 + qnorm(0.975) * S_S2021
SigLB_2021
SigUB_2021
s_2022 <- sd(INTClogRet["2022",])
s_2022
n_2022 <- nrow(INTClogRet["2022",])
S_S2022 <- (s_2022/2) * sqrt( ( K_2022 * (n_2022/(n_2022-1))^2 - (n_2022-3)/(n_2022-1) ) / n_2022 )
K_2022 <- kurtosis(INTClogRet["2022",])
K_2022
S_S2022 <- (s_2022/2) * sqrt( ( K_2022 * (n_2022/(n_2022-1))^2 - (n_2022-3)/(n_2022-1) ) / n_2022 )
S_S2022
SigLB_2022 <- s_2022 - qnorm(0.975) * S_S2022
SigUB_2022 <- s_2022 + qnorm(0.975) * S_S2022
SigLB_2022
SigUB_2022
xbar_2022 <- mean(INTClogRet["2022",])
xbar_2023 <- mean(INTClogRet["2023",])
xbar_2023
xbar_2023
xbar_2022
s_2023 <- sd(INTClogRet["2023",])
s_2023
n_2023 <- nrow(INTClogRet["2023",])
n_2023
s_xbar23mxbar22 <- sqrt(s_2023^2/n_2023 + s_2022^2/n_2022)
s_xbar23mxbar22
TS_mu23vsmus22 <- (xbar_2023-xbar_2022) / s_xbar23mxbar22
?pnorm
pv_mu23vsmus23 <-  pnorm(TS_mu22vsmus21,mean=0,sd=1,lower.tail=FALSE)
pv_mu23vsmus23 <-  pnorm(TS_mu23vsmus22,mean=0,sd=1,lower.tail=FALSE)
