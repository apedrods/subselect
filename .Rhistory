setwd("C:/Users/psilva/Desktop")
loanDF <- read.csv("loan_data.csv")
head(loanDF)
summary(loanDF)
#Removing observations with missing data
unvalidobs <- c(which(loanDF$annual_inc==0.), which(loanDF$revol_bal==0), which(apply(loanDF,1,function(obs) any(is.na(obs)))))
valid_loanDF <- loanDF[-unvalidobs,]
summary(valid_loanDF)
# log-transformations
loandDF1 <- transform(valid_loanDF,ln_annual_income=log(annual_inc),ln_revolving_balance=log(revol_bal))
summary(loandDF1)
#transform character variables into factors    (Jan 2022)
loandDF1 <- transform(loandDF1,grade=as.factor(grade),sub_grade=as.factor(sub_grade),purpose=as.factor(purpose)) # (Jan 2022)
summary(loandDF1) # (Jan 2022)
#Min-Max standard aggregation
loand_Idt_MinMax <- AgrMcDt(loandDF1[,c("ln_annual_income","int_rate","open_acc","total_acc")],agrby=loandDF1$sub_grade)
library(MAINT.Data)
#Min-Max standard aggregation
loand_Idt_MinMax <- AgrMcDt(loandDF1[,c("ln_annual_income","int_rate","open_acc","total_acc")],agrby=loandDF1$sub_grade)
print(loand_Idt_MinMax)
summary(loand_Idt_MinMax)
#Robust (quantile-based) aggregation
loand_Idt_prc1090 <- AgrMcDt(loandDF1[,c("ln_annual_income","int_rate","open_acc","total_acc")],agrby=loandDF1$sub_grade,agrcrt =c(0.1,0.9))
print(loand_Idt_prc1090)
summary(loand_Idt_prc1090)
#Groups definition
Idtgrades <- substr(rownames(loand_Idt_MinMax),1,1)
RiskF <- factor(ifelse(Idtgrades=="A" | Idtgrades=="B","Low",ifelse(Idtgrades=="C" | Idtgrades=="D","Medium","High")))
print(RiskF)
#Plotting the interval data
plot(loand_Idt_MinMax[,"int_rate"],loand_Idt_MinMax[,"ln_annual_income"])
plot(loand_Idt_prc1090[,"int_rate"],loand_Idt_prc1090[,"ln_annual_income"])
plot(loand_Idt_MinMax[,"open_acc"],loand_Idt_MinMax[,"total_acc"])
plot(loand_Idt_prc1090[,"open_acc"],loand_Idt_prc1090[,"total_acc"])
mleEst_MinMax <- mle(loand_Idt_MinMax,Model="NrmandSKN")
print(mleEst_MinMax)
mleEst_prc1090 <- mle(loand_Idt_prc1090,Model="NrmandSKN")
print(mleEst_prc1090)
mleEst_MinMax_C3 <- mle(loand_Idt_MinMax,Model="NrmandSKN",CovCase=3)
print(mleEst_MinMax_C3)
mleEst_prc1090_C3 <- mle(loand_Idt_prc1090,Model="NrmandSKN",CovCase=3)
print(mleEst_prc1090_C3)
#robust estimation
RobEst_MinMax <- fasttle(loand_Idt_MinMax)
print(RobEst_MinMax)
#RobEst_prc1090 <- fasttle(loand_Idt_prc1090)
RobEst_prc1090 <- fasttle(loand_Idt_prc1090,CovCase=2:4)
print(RobEst_prc1090)
#outlier identification
Otl_MinMax <- getIdtOutl(loand_Idt_MinMax,RobEst_MinMax)
print(Otl_MinMax)
plot(Otl_MinMax)
Otl_prc1090 <- getIdtOutl(loand_Idt_prc1090,RobEst_prc1090)
print(Otl_prc1090)
plot(Otl_prc1090)
DACrossVal(loand_Idt_MinMax,RiskF,TrainAlg=lda,loo=TRUE)
DACrossVal(loand_Idt_MinMax,RiskF,TrainAlg=qda,loo=TRUE)
DACrossVal(loand_Idt_MinMax,RiskF,TrainAlg=snda,loo=TRUE)
lda_rule_MinMax <- lda(loand_Idt_MinMax,RiskF)
lda_pred_MinMax <- predict(lda_rule_MinMax,loand_Idt_MinMax)
print(lda_pred_MinMax)$class
DACrossVal(loand_Idt_prc1090,RiskF,TrainAlg=lda,loo=TRUE)
DACrossVal(loand_Idt_prc1090,RiskF,TrainAlg=qda,loo=TRUE)
